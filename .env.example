# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: account deletion + optional dev auto-confirm (see README)
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — set to your real production domain (e.g. https://noregrets-hazel.vercel.app).
# Used for signup email redirects from server actions. If unset on Vercel, we fall back to VERCEL_URL.
# For password reset, the browser uses the page you’re on unless this is a non-localhost URL.
# Supabase → Authentication → Site URL must match this host (not http://localhost:3001).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local-only: skip email confirmation (requires SUPABASE_SERVICE_ROLE_KEY). Never true in production.
AUTH_DEV_AUTO_CONFIRM=false

# Supabase → Authentication → URL configuration:
# - Site URL: same as NEXT_PUBLIC_APP_URL (production URL in prod).
# - Redirect URLs: include {NEXT_PUBLIC_APP_URL}/auth/callback and /auth/update-password if needed.
#
# Email templates: use the OTP / {{ .Token }} style for signup and recovery so users can paste codes.
# (Magic links still work alongside codes.)

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=

# Resend (https://resend.com) — verified domain for `from`
RESEND_API_KEY=
RESEND_FROM_EMAIL=NoRegrets <onboarding@yourdomain.com>

# Cron / Vercel Cron — protect reminder endpoint
CRON_SECRET=generate-a-long-random-string
