# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: account deletion + dev auto-confirm signup (see below)
SUPABASE_SERVICE_ROLE_KEY=

# Local dev: create pre-confirmed users and sign them in immediately (requires service role above).
# Never set to true in production.
AUTH_DEV_AUTO_CONFIRM=true

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=

# Resend (https://resend.com) — verified domain for `from`
RESEND_API_KEY=
RESEND_FROM_EMAIL=NoRegrets <onboarding@yourdomain.com>

# Cron / Vercel Cron — protect reminder endpoint
CRON_SECRET=generate-a-long-random-string

# App URL (for email links — match your dev port, e.g. 3001)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Supabase Dashboard → Authentication → URL configuration:
# - Site URL: e.g. http://localhost:3001
# - Redirect URLs: add http://localhost:3001/auth/callback (needed for email confirmation)
